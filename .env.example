# KikiMundialista — Variables de Entorno

# ⚠️  Copia este archivo como .env.local y completa con tus valores de Firebase Console
# ⚠️  NUNCA subas .env.local a Git (ya está en .gitignore)

# Firebase Project Config
# Obtenlos en: Firebase Console → Project Settings → Tu app web
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# App Config
VITE_APP_NAME=KikiMundialista
VITE_APP_SEASON=Mundial 2026
